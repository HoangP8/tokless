{
  "name": "tokless",
  "version": "0.1.0",
  "description": "One-shot global installer for token-saving AI coding tools (RTK, Caveman, CodeGraph, Context-Mode) across Claude Code, OpenCode, and Codex.",
  "type": "module",
  "scripts": {
    "dev": "bun src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "bun test/unit.ts",
    "test:integration": "TOKLESS_TEST=1 bun test/run.ts",
    "test": "bun run typecheck && bun run test:unit && bun run test:integration && bun run test:real",
    "test:real": "bun test/real.ts",
    "testbed:generate": "bun testbed/generate.ts",
    "build:release": "bun scripts/build-release.ts"
  },
  "keywords": [
    "ai",
    "llm",
    "tokens",
    "claude-code",
    "opencode",
    "codex",
    "mcp",
    "rtk",
    "caveman",
    "codegraph",
    "context-mode",
    "token-optimization"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HoangP8/tokless"
  },
  "homepage": "https://github.com/HoangP8/tokless#readme",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "5.4"
  }
}
